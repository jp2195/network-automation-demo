  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "UP"
                },
                "2": {
                  "color": "red",
                  "text": "DOWN"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "red",
                "value": 1.5
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 24,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "view": {
          "id": "coords",
          "lat": 33.78,
          "lon": -84.39,
          "zoom": 9.7
        },
        "controls": {
          "showZoom": true,
          "showAttribution": true,
          "showScale": true,
          "showDebug": false,
          "showMeasure": true,
          "mouseWheelZoom": true
        },
        "tooltip": {
          "mode": "details"
        },
        "basemap": {
          "type": "default",
          "name": "Layer 0",
          "config": {}
        },
        "layers": [
          {
            "type": "route",
            "name": "Backbone fiber rings",
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "filterData": {
              "id": "byRefId",
              "options": "L.*"
            },
            "config": {
              "style": {
                "color": {
                  "field": "Value"
                },
                "lineWidth": 4,
                "opacity": 0.9
              },
              "arrow": 0
            },
            "tooltip": true
          },
          {
            "type": "markers",
            "name": "Cabinets (FRR / SNMP)",
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "filterData": {
              "id": "byRefId",
              "options": "A"
            },
            "config": {
              "showLegend": true,
              "style": {
                "color": {
                  "field": "Value"
                },
                "size": {
                  "fixed": 10
                },
                "symbol": {
                  "fixed": "img/icons/marker/triangle.svg",
                  "mode": "fixed"
                },
                "textConfig": {
                  "fontSize": 11,
                  "offsetX": 0,
                  "offsetY": 14,
                  "textAlign": "center",
                  "textBaseline": "top"
                },
                "text": {
                  "field": "node"
                },
                "opacity": 0.95
              }
            },
            "tooltip": true
          },
          {
            "type": "markers",
            "name": "Backbone hubs (SR Linux / gNMI)",
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "filterData": {
              "id": "byRefId",
              "options": "B"
            },
            "config": {
              "showLegend": true,
              "style": {
                "color": {
                  "field": "Value"
                },
                "size": {
                  "fixed": 16
                },
                "symbol": {
                  "fixed": "img/icons/marker/circle.svg",
                  "mode": "fixed"
                },
                "textConfig": {
                  "fontSize": 13,
                  "offsetX": 0,
                  "offsetY": -18,
                  "textAlign": "center",
                  "textBaseline": "bottom"
                },
                "text": {
                  "field": "node"
                },
                "opacity": 0.95
              }
            },
            "tooltip": true
          }
        ]
      },
      "title": "Atlanta metro \u2014 Atlas DOT Region 7",
      "type": "geomap",
      "targets": [
        {
          "expr": "max by (node, lat, lon, site, city, role, kind) (device_geo_info{kind=\"frr\"} * on(node) group_right(lat, lon, site, city, role, kind) (2 - up{job=\"snmp-frr-cabinets\"}))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "max by (node, lat, lon, site, city, role, kind) (device_geo_info{kind=\"srlinux\"} * on(node) group_right(lat, lon, site, city, role, kind) (srl_nokia_interfaces_interface_oper_state * on(node, interface) group_left link_membership_info))",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "link_endpoint_geo * on(link_id) group_left(link_kind, corridor) max by(link_id, link_kind, corridor) (link:oper_state_with_meta)",
          "format": "table",
          "instant": true,
          "refId": "L",
          "legendFormat": "{{link_id}}"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "lat",
                "destinationType": "number"
              },
              {
                "targetField": "lon",
                "destinationType": "number"
              }
            ],
            "fields": {}
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "network",
    "atlas-dot",
    "demo",
    "geomap"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "title": "Atlanta metro \u2014 Geomap",
  "uid": "geomap",
  "version": 1
