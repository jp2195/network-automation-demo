            "indexByName": {
              "Value": 3,
              "interface": 0,
              "link_id": 1,
              "link_kind": 2
            },
            "renameByName": {
              "Value": "Oper",
              "interface": "Interface",
              "link_id": "Link",
              "link_kind": "Kind"
            }
          }
        }
      ],
      "type": "table"
