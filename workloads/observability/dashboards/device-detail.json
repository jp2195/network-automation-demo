              "__name__": true,
              "city": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "interface_name": true,
              "job": true,
              "namespace": true,
              "node": true,
              "pod": true,
              "prometheus": true,
              "role": true,
              "service": true,
              "site": true,
              "source": true,
              "subscription_name": true
