                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 13,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 6,
      "options": {
        "cellHeight": "md",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Group"
          },
          {
            "desc": false,
            "displayName": "Node"
          }
        ]
      },
      "targets": [
        {
          "expr": "bgp_peer_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "BGP peers",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "prometheus": true,
              "service": true
            },
            "indexByName": {
              "neighbor_node": 1,
              "node": 0,
              "peer_address": 2,
              "peer_as": 3,
              "peer_group": 4
            },
            "renameByName": {
              "neighbor_node": "Peer",
              "node": "Node",
              "peer_address": "Address",
              "peer_as": "AS",
              "peer_group": "Group"
            }
          }
        },
        {
          "id": "merge"
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": true
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "max": 1.5,
          "min": 0.5
