      },
      "targets": [
        {
          "expr": "isis_adjacency_info * on(node, interface) (srl_nokia_interfaces_interface_oper_state == bool 1)",
          "legendFormat": "{{node}} → {{neighbor}} ({{interface}})",
          "refId": "A"
        }
      ],
      "title": "IS-IS adjacency state — 30 minutes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
