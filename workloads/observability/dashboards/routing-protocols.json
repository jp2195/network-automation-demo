    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "red",
                "value": 1.5
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "text": "✗ DOWN"
                      },
                      "1": {
                        "color": "green",
                        "text": "✓ UP"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Uptime (s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Node"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open device",
                    "url": "/d/device-detail/device-detail?var-node=${__value.text}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Link"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open link",
                    "url": "/d/link-detail/link-detail?var-link_id=${__value.text}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 13,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 5,
      "options": {
        "cellHeight": "md",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "State"
          },
          {
            "desc": false,
            "displayName": "Node"
          }
        ]
      },
      "targets": [
        {
          "expr": "(isis_adjacency_info * on(node, interface) group_left() (srl_nokia_interfaces_interface_oper_state == bool 1))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "isis_adjacency_uptime_seconds",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "IS-IS adjacencies",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "neighbor",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "interface 2": true,
              "level 1": true,
              "level 2": true,
              "link_id 2": true,
              "node 2": true,
              "system_id 1": true,
              "system_id 2": true
            },
            "indexByName": {
              "Value #A": 4,
              "Value #B": 5,
              "interface 1": 1,
              "link_id 1": 3,
              "neighbor": 2,
              "node 1": 0
            },
            "renameByName": {
              "Value #A": "State",
              "Value #B": "Uptime (s)",
              "interface 1": "Interface",
              "link_id 1": "Link",
              "neighbor": "Neighbor",
              "node 1": "Node"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
