    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "minVizHeight": 75,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "100 * (link:p95_out_bps:30m{link_kind=\"backbone\"} / 1e10)",
          "legendFormat": "{{link_id}}",
          "refId": "A"
        }
      ],
      "title": "Per-link 95th-percentile utilization (% of 10G, last 1h)",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "spanNulls": true
          },
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "expr": "link:rate_out_bps:1m{link_kind=\"backbone\"}",
          "legendFormat": "{{link_id}}",
          "refId": "A"
        }
      ],
      "title": "Per-link traffic — backbone egress",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "spanNulls": true
          },
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "expr": "link:p95_out_bps:30m{link_kind=\"backbone\"}",
          "legendFormat": "p95 {{link_id}}",
          "refId": "A"
        }
      ],
      "title": "Per-link 95th-percentile (rolling 30 min)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p95 (Mbps)"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              },
              {
                "id": "max",
                "value": 10000
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 5000
                    },
                    {
                      "color": "red",
                      "value": 8000
                    }
                  ]
                }
              },
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Utilization"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Link"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open link",
                    "url": "/d/link-detail/link-detail?var-link_id=${__value.text}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 4,
      "options": {
        "cellHeight": "md",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Utilization"
          }
        ]
      },
      "targets": [
        {
          "expr": "(link:p95_out_bps:30m{link_kind=\"backbone\"} / 1e6)",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "(link:p95_out_bps:30m{link_kind=\"backbone\"} / 1e10) * 100",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "Capacity table — links sorted by 1h p95",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "link_id",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true
            },
            "indexByName": {
              "Value #A": 1,
              "Value #B": 2,
              "link_id": 0
            },
            "renameByName": {
              "Value #A": "p95 (Mbps)",
              "Value #B": "Utilization",
              "link_id": "Link"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "expr": "topk(8, sum by (node) (rate(srl_nokia_interfaces_interface_statistics_out_octets[1m]) * on(node, interface) group_left link_membership_info))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Top talkers — outbound bytes/s by node",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "network",
    "atlas-dot",
    "demo",
    "capacity"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Capacity planning",
  "uid": "capacity-planning",
  "version": 1
}
