apiVersion: argoproj.io/v1alpha1
kind: WorkflowTemplate
metadata:
  name: gray-failure
spec:
  serviceAccountName: operate-workflow-sa
  entrypoint: apply
  volumes:
    - name: scripts
      configMap:
        name: workflow-scripts
  arguments:
    parameters:
      - name: link
      - name: action
        value: start
  templates:
    - name: apply
      inputs:
        parameters:
          - name: link
          - name: action
      script:
        image: @@EVENTING_IMAGE@@
        command: [python3]
        source: |
          import sys, runpy
          sys.path.insert(0, "/scripts")
          runpy.run_path("/scripts/gray_key.py", run_name="__main__")
        volumeMounts:
          - name: scripts
            mountPath: /scripts
        env:
          - name: LINK
            value: "{{inputs.parameters.link}}"
          - name: ACTION
            value: "{{inputs.parameters.action}}"
          - name: VALKEY_URL
            value: valkey://valkey.valkey.svc.cluster.local:6379/3
        resources:
          requests: {cpu: 50m, memory: 64Mi}
          limits:   {memory: 128Mi}
