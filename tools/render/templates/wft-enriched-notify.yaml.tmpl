apiVersion: argoproj.io/v1alpha1
kind: WorkflowTemplate
metadata:
  name: enriched-notify
spec:
  serviceAccountName: operate-workflow-sa
  entrypoint: main
  arguments:
    parameters:
      - name: alert
  volumes:
    - name: scripts
      configMap:
        name: workflow-scripts
  templates:
    - name: main
      inputs:
        parameters:
          - name: alert
      dag:
        tasks:
          - name: enrich
            template: enrich
            arguments:
              parameters:
                - name: alert
                  value: "{{inputs.parameters.alert}}"
          - name: analyze
            template: analyze
            dependencies: [enrich]
            arguments:
              parameters:
                - name: enrichment
                  value: "{{tasks.enrich.outputs.result}}"
          - name: notify
            template: notify
            dependencies: [analyze]
            arguments:
              parameters:
                - name: enrichment
                  value: "{{tasks.enrich.outputs.result}}"
                - name: impact
                  value: "{{tasks.analyze.outputs.result}}"
          - name: dashboard
            template: dashboard
            dependencies: [analyze]
            arguments:
              parameters:
                - name: enrichment
                  value: "{{tasks.enrich.outputs.result}}"
                - name: impact
                  value: "{{tasks.analyze.outputs.result}}"
          - name: postmortem
            template: postmortem
            dependencies: [notify]
            # Skipped on firing alerts; runs only on the resolved path.
            when: "'{{tasks.notify.outputs.parameters.status}}' == 'resolved'"
            arguments:
              parameters:
                - name: enrichment
                  value: "{{tasks.enrich.outputs.result}}"
                - name: impact
                  value: "{{tasks.analyze.outputs.result}}"
                - name: notify_result
                  value: "{{tasks.notify.outputs.result}}"

    - name: enrich
      inputs:
        parameters:
          - name: alert
      script:
        image: python:3.12-slim
        command: [python3]
        source: |
          import sys, runpy
          sys.path.insert(0, "/scripts")
          runpy.run_path("/scripts/enrich.py", run_name="__main__")
        env:
          # Inject the alert payload via env value rather than a triple-quoted
          # python string. Substituting JSON containing \n (description block)
          # into """...""" makes Python interpret \n as a newline, producing
          # an unescaped control char that breaks json.loads. As an env value
          # the parameter substitution stays at the YAML-scalar layer.
          - name: ALERT_JSON
            value: "{{inputs.parameters.alert}}"
          - name: NETBOX_URL
            value: http://netbox.netbox.svc.cluster.local
          - name: NETBOX_TOKEN
            valueFrom:
              secretKeyRef:
                # Mirrored by the netbox-seed Job after a fresh `tokens/provision/`
                # call. NetBox 4.x hashes API tokens at rest, so the value can't
                # be pinned at config-time — the Secret is the source of truth.
                name: netbox-api
                key: token
        volumeMounts:
          - name: scripts
            mountPath: /scripts
        resources:
          requests:
            cpu: 50m
            memory: 64Mi
          limits:
            memory: 128Mi

    - name: analyze
      inputs:
        parameters:
          - name: enrichment
      script:
        image: python:3.12-slim
        command: [python3]
        source: |
          import sys, runpy
          sys.path.insert(0, "/scripts")
          runpy.run_path("/scripts/analyze_impact.py", run_name="__main__")
        env:
          - name: ENRICHMENT_JSON
            value: "{{inputs.parameters.enrichment}}"
          - name: NETBOX_URL
            value: http://netbox.netbox.svc.cluster.local
          - name: NETBOX_TOKEN
            valueFrom:
              secretKeyRef:
                # Mirrored by the netbox-seed Job after a fresh `tokens/provision/`
                # call. NetBox 4.x hashes API tokens at rest, so the value can't
                # be pinned at config-time — the Secret is the source of truth.
                name: netbox-api
                key: token
          # Backup-path derivation cross-checks the ring's LIVE oper-state.
          - name: PROM_URL
            value: http://kps-kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
        volumeMounts:
          - name: scripts
            mountPath: /scripts
        resources:
          requests:
            cpu: 50m
            memory: 64Mi
          limits:
            memory: 128Mi

    - name: dashboard
      inputs:
        parameters:
          - name: enrichment
          - name: impact
      script:
        image: @@EVENTING_IMAGE@@
        command: [python3]
        source: |
          import sys, runpy
          sys.path.insert(0, "/scripts")
          runpy.run_path("/scripts/incident_dashboard.py", run_name="__main__")
        env:
          - name: ENRICHMENT_JSON
            value: "{{inputs.parameters.enrichment}}"
          - name: IMPACT_JSON
            value: "{{inputs.parameters.impact}}"
        volumeMounts:
          - name: scripts
            mountPath: /scripts
        resources:
          requests:
            cpu: 50m
            memory: 96Mi
          limits:
            memory: 192Mi

    - name: notify
      inputs:
        parameters:
          - name: enrichment
          - name: impact
      script:
        image: @@EVENTING_IMAGE@@
        command: [python3]
        source: |
          import sys, runpy
          sys.path.insert(0, "/scripts")
          runpy.run_path("/scripts/notify.py", run_name="__main__")
        env:
          - name: ENRICHMENT_JSON
            value: "{{inputs.parameters.enrichment}}"
          - name: IMPACT_JSON
            value: "{{inputs.parameters.impact}}"
          # Slack creds are optional — if the `slack-bot` Secret doesn't
          # exist (the default), notify.py short-circuits to stderr-printed
          # Block Kit payloads. To enable real Slack posting, see SECRETS.md.
          - name: SLACK_BOT_TOKEN
            valueFrom:
              secretKeyRef:
                name: slack-bot
                key: bot_token
                optional: true
          - name: SLACK_CHANNEL_ID
            valueFrom:
              secretKeyRef:
                name: slack-bot
                key: channel_id
                optional: true
          - name: VALKEY_URL
            value: valkey://valkey.valkey.svc.cluster.local:6379/2
        volumeMounts:
          - name: scripts
            mountPath: /scripts
        resources:
          requests:
            cpu: 50m
            memory: 96Mi
          limits:
            memory: 192Mi
      outputs:
        parameters:
          - name: status
            valueFrom:
              path: /tmp/argo/status
              # If notify couldn't write the file, gate postmortem closed.
              default: firing

    - name: postmortem
      inputs:
        parameters:
          - name: enrichment
          - name: impact
          - name: notify_result
      script:
        image: @@EVENTING_IMAGE@@
        command: [python3]
        source: |
          import sys, runpy
          sys.path.insert(0, "/scripts")
          runpy.run_path("/scripts/postmortem.py", run_name="__main__")
        env:
          - name: ENRICHMENT_JSON
            value: "{{inputs.parameters.enrichment}}"
          - name: IMPACT_JSON
            value: "{{inputs.parameters.impact}}"
          - name: NOTIFY_JSON
            value: "{{inputs.parameters.notify_result}}"
          - name: VALKEY_URL
            value: valkey://valkey.valkey.svc.cluster.local:6379/2
          - name: PROM_URL
            value: http://kps-kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
          - name: LOKI_URL
            value: http://loki-gateway.monitoring.svc.cluster.local
        volumeMounts:
          - name: scripts
            mountPath: /scripts
        resources:
          requests:
            cpu: 50m
            memory: 96Mi
          limits:
            memory: 192Mi
